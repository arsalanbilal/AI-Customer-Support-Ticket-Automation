# Copy this file to .env and fill in real values.
# Nothing in this file is a real secret - these are placeholders.

# --- LLM (Google Gemini) - required ---
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
LLM_MAX_RETRIES=3
LLM_RETRY_BACKOFF_SECONDS=2

# --- Storage paths - optional, sensible defaults provided ---
SQLITE_PATH=./data/tickets.db
ATTACHMENTS_DIR=./data/attachments
LOG_DIR=./logs

# --- Outbound acknowledgement email (SMTP) - optional ---
# If left blank, the app still works; it just logs "SMTP not configured"
# instead of sending the acknowledgement email.
AUTO_SEND_ACK=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=your_email@gmail.com
SMTP_USE_TLS=true

# --- Inbound inbox monitoring (IMAP) - optional ---
# If left blank, "Fetch new emails" in the UI will simply return no results.
# Use manual entry or "Load sample_emails.json" instead for a demo.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=your_email@gmail.com
IMAP_PASSWORD=your_app_password
IMAP_FOLDER=INBOX
IMAP_MARK_SEEN=true
IMAP_POLL_SECONDS=60

# --- Ticket platform integration (Airtable) - optional ---
# If left blank, tickets are only stored locally in SQLite.
AIRTABLE_API_KEY=your_airtable_personal_access_token
AIRTABLE_BASE_ID=your_airtable_base_id
AIRTABLE_TABLE_NAME=Tickets

# --- Duplicate detection ---
DUPLICATE_LOOKBACK_DAYS=7
DUPLICATE_SIMILARITY_THRESHOLD=85

# --- Team routing config file (category -> team) ---
TEAM_MAPPING_PATH=./team_mapping.json
